# 根据自己情况修改添加
# LLM 模型相关 API
API_KEY = ""
BASE_URL = ""
LLM_MODEL = ""

# 工具调用默认不按轮次截断。若部署方需要兜底保护，可设置为正整数。
# LAWVER_MAX_TOOL_ROUNDS = ""
# LAWVER_MAX_NON_STREAM_TOOL_ROUNDS = ""

# 应用认证配置
# SECRET_KEY 必须至少 32 位；生产环境请使用随机值，例如 openssl rand -hex 32
SECRET_KEY = ""
# 首次启动且 data/account.json 不存在时用于创建 admin 账号；创建后可移除
INITIAL_ADMIN_PASSWORD = ""

# OCP (Output Check Process) 审查 LLM 配置（可选，未设置时回退到主模型配置）
# OCP_API_KEY = ""
# OCP_BASE_URL = ""
# OCP_LLM_MODEL = ""

# 对话记忆 embedding 权重召回（可选，默认关闭；开启后作为多路召回的一路参与 RAG 权重排序）
# MEMORY_EMBEDDING_ENABLED = "1"
# EMBEDDING_API_KEY = ""
# EMBEDDING_BASE_URL = "https://api.siliconflow.cn/v1"
# EMBEDDING_MODEL = "Qwen/Qwen3-Embedding-8B"
# MEMORY_EMBEDDING_TIMEOUT = "8"
# MEMORY_EMBEDDING_MAX_RESPONSE_BYTES = "8388608"

# 对话级记忆服务端活跃缓存（用户侧快照仍是主持久源）
# LAWVER_MEMORY_DB = "data/memory_cache.sqlite3"
# LAWVER_MEMORY_CACHE_TTL_SECONDS = "604800"
# LAWVER_MEMORY_MAX_SCOPES = "512"
# LAWVER_MEMORY_LOG_LEVEL = "INFO"

# ## ModelScope搜索 - 获取API密钥：https://modelscope.cn/
# MODELSCOPE_API_KEY=""
# MODELSCOPE_BASE_URL="https://api-inference.modelscope.cn/v1/"
# MODELSCOPE_MODEL_ID="Qwen/Qwen3.5-397B-A17B" # ModelScope 只能使用 Qwen3.5


# Tools 相关配置#

# 得理 API：https://openapi.delilegal.com/
DELI_APPID=""
DELI_SECRET=""

# 北大法宝api：https://mcp.pkulaw.com/console
PKU_ACCESS_TOKEN="YOUR_ACCESS_HERE"

# 天气搜索 - 获取API密钥：https://tavily.com/
TAVILY_API_KEY=""

# 网页搜索 - 获取API密钥：https://serpapi.com/
SERPAPI_API_KEY=""
