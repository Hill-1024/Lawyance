# 根据自己情况修改添加
# LLM 模型相关 API
API_KEY = ""
BASE_URL = ""
LLM_MODEL = ""

# 工具调用默认不按轮次截断。若部署方需要兜底保护，可设置为正整数。
# LAWYANCE_MAX_TOOL_ROUNDS = ""
# LAWYANCE_MAX_NON_STREAM_TOOL_ROUNDS = ""

# 应用认证配置
# SECRET_KEY 必须至少 32 位；生产环境请使用随机值，例如 openssl rand -hex 32
SECRET_KEY = ""
# 首次启动且 data/account.json 不存在时用于创建 admin 账号；创建后可移除
INITIAL_ADMIN_PASSWORD = ""

# OCP (Output Check Process) 审查 LLM 配置（可选，未设置时回退到主模型配置）
# OCP_API_KEY = ""
# OCP_BASE_URL = ""
# OCP_LLM_MODEL = ""

# ## ModelScope搜索 - 获取API密钥：https://modelscope.cn/
# MODELSCOPE_API_KEY=""
# MODELSCOPE_BASE_URL="https://api-inference.modelscope.cn/v1/"
# MODELSCOPE_MODEL_ID="Qwen/Qwen3.5-397B-A17B" # ModelScope 只能使用 Qwen3.5


# Tools 相关配置#

# 得理 API：https://openapi.delilegal.com/
DELI_APPID=""
DELI_SECRET=""

# 北大法宝api：https://mcp.pkulaw.com/console
PKU_ACCESS_TOKEN="YOUR_ACCESS_HERE"

# 天气搜索 - 获取API密钥：https://tavily.com/
TAVILY_API_KEY=""

# 网页搜索 - 获取API密钥：https://serpapi.com/
SERPAPI_API_KEY=""
